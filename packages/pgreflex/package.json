{
  "name": "pgreflex",
  "version": "0.0.1",
  "description": "Reactive Postgres",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/moritzuehling/pgreflex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzuehling/pgreflex.git"
  },
  "author": "Moritz Uehling <git@moritzuehling.de>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./connection/auth": "./dist/connection/auth.mjs",
    "./connection/certificate": "./dist/connection/certificate.mjs",
    "./connection/socket": "./dist/connection/socket.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "bumpp": "^10.4.0",
    "tsdown": "^0.18.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@trpc/server": "^11.8.1",
    "drizzle-orm": "^0.45.1"
  },
  "dependencies": {
    "@peculiar/x509": "^1.14.3"
  }
}
